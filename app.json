{
  "expo": {
    "name": "GlowDermics",
    "slug": "glowdermics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "glowdermics",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tallowdermics.glowdermics",
      "infoPlist": {
        "NSCameraUsageDescription": "GlowDermics uses your camera to scan and analyze your skin.",
        "NSPhotoLibraryUsageDescription": "GlowDermics accesses your photos to analyze your skin progress.",
        "NSPhotoLibraryAddUsageDescription": "GlowDermics saves your skin scan results to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.tallowdermics.glowdermics",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow GlowDermics to access Face ID to secure your account."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
