# Velumi affiliate-link substitution — copy to .env.local (gitignored) and fill in.
# Each tag wraps outbound product links so Velumi earns commission. See
# docs/VELUMI_LAUNCH_LINKS.md for signup URLs + payout rates.

# Amazon Associates US — paste the full tag (format: yourname-20)
EXPO_PUBLIC_AMAZON_TAG=

# Skimlinks (auto-monetises any retail link if you don't have direct programs)
EXPO_PUBLIC_SKIMLINKS_PUB_ID=

# Impact (CeraVe, La Roche-Posay, Glossier, many others)
EXPO_PUBLIC_IMPACT_PUBLISHER_ID=

# Rakuten Advertising (Sephora, Walgreens)
EXPO_PUBLIC_RAKUTEN_PUB_ID=

# CJ Affiliate (Ulta, iHerb)
EXPO_PUBLIC_CJ_PUB_ID=

# Awin / ShareASale
EXPO_PUBLIC_AWIN_AFF_ID=
EXPO_PUBLIC_SHAREASALE_AFF_ID=
